{
  "poems": [
    {
      "title": "Bumerang",
      "author": "Joachim Ringelnatz",
      "lines": [
        "War einmal ein Bumerang;",
        "War ein Weniges zu lang.",
        "Bumerang flog ein Stück,",
        "Aber kam nicht mehr zurück.",
        "Publikum - noch stundenlang -",
        "wartete auf Bumerang."
      ]
    }
  ]
}
